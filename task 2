#include<iostream>
#include<string>
using namespace std;


template <typename t>

class storing {
public:
	int index;
	t arr[5];
	storing():index(0){}
	void setvalue(int a, t value) {
		if (a >= 0 && a <= 5) {
			arr[a] = value;
			index++;
		}
		else
			cout << "index out off range" << endl;

	}

	t getvalue(int a) {
		return arr[a];
	}
	void display() {
		cout << "values: " ;
		for (int i = 0;i < index;i++)
		{
			cout << arr[i] << " " ;
		}
		
	}

};

int main() {
	storing<int> obj;
	obj.setvalue(0, 1);
	obj.setvalue(1, 2);
	obj.setvalue(2, 3);
	obj.setvalue(3, 4);
	obj.setvalue(7, 5);
	obj.display();
	cout << endl;

	storing<double> obj1;
	obj1.setvalue(0, 0.5);
	obj1.setvalue(1, 0.1);
	obj1.setvalue(2, 0.3);
	obj1.setvalue(3, 0.4);
	obj1.setvalue(4, 0.5);
	obj1.display();
}
